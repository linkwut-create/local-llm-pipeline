{
  "_note": "All profiles use openai-compatible backend via LiteLLM (zero12:4000). Ollama is deprecated.",
  "default_profile": "code_worker",

  "profiles": {
    "fast_summary": {
      "model": "qwen3.6-default",
      "temperature": 0.2,
      "max_chars": 24000,
      "max_output_chars": 3000,
      "max_output_tokens": 16384,
      "use_for": ["summarize-file", "summarize-tree"],
      "candidates": ["qwen3.6-default", "qwen3-coder-30b"],
      "risk_level": "low",
      "_backend_class": "openai-compatible",
      "_residency": "resident",
      "_note": "Uses resident qwen3.6-27b. Fast enough for summaries, no need for separate gemma model."
    },
    "code_worker": {
      "model": "qwen3-coder-30b",
      "temperature": 0.1,
      "max_chars": 40000,
      "max_output_chars": 4000,
      "max_output_tokens": 16384,
      "use_for": ["generate-test-plan", "generate-test-draft", "extract-todos", "find-related-files"],
      "candidates": ["qwen3-coder-30b", "qwen3.6-default"],
      "risk_level": "medium",
      "_backend_class": "openai-compatible",
      "_residency": "resident",
      "_note": "Primary code worker. Resident on 8003."
    },
    "commit_reviewer": {
      "model": "qwen3-coder-30b",
      "temperature": 0.1,
      "max_chars": 40000,
      "max_output_chars": 4000,
      "max_output_tokens": 16384,
      "use_for": ["review-diff"],
      "candidates": ["qwen3-coder-30b", "qwen3.6-default"],
      "risk_level": "medium",
      "_backend_class": "openai-compatible",
      "_residency": "resident",
      "_commit_gate_allowed": true,
      "_note": "Commit gate reviewer. Must be resident (low latency)."
    },
    "diff_reviewer": {
      "model": "nemotron-30b",
      "temperature": 0.1,
      "max_chars": 60000,
      "max_output_chars": 6000,
      "max_output_tokens": 16384,
      "use_for": ["review-diff", "deep-code-review"],
      "candidates": ["nemotron-30b", "qwen3-coder-30b"],
      "risk_level": "medium",
      "_backend_class": "openai-compatible",
      "_residency": "on_demand",
      "_systemd": "nemotron-30b-llama.service",
      "_note": "Nemotron 30B for deeper code review. On-demand via systemd."
    },
    "deep_reviewer": {
      "model": "qwen3.6-deep",
      "temperature": 0.1,
      "max_chars": 60000,
      "max_output_chars": 6000,
      "max_output_tokens": 16384,
      "use_for": ["architecture-review", "risk-analysis", "logic-check"],
      "candidates": ["qwen3.6-deep", "deepseek-r1-32b"],
      "risk_level": "high",
      "_backend_class": "openai-compatible",
      "_residency": "resident",
      "_note": "Deep reasoning on resident qwen3.6-27b. Slower due to built-in thinking."
    },
    "reasoning_checker": {
      "model": "deepseek-r1-32b",
      "temperature": 0.0,
      "max_chars": 60000,
      "max_output_chars": 6000,
      "max_output_tokens": 16384,
      "use_for": ["risk-analysis", "safety-check", "logic-check"],
      "candidates": ["deepseek-r1-32b", "qwen3.6-deep"],
      "risk_level": "high",
      "_backend_class": "openai-compatible",
      "_residency": "on_demand",
      "_systemd": "deepseek-r1-32b-llama.service",
      "_note": "DeepSeek R1 for high-risk reasoning. On-demand only — 32B model."
    },
    "translation": {
      "model": "glm-4.7-flash",
      "temperature": 0.1,
      "max_chars": 20000,
      "max_output_chars": 4000,
      "max_output_tokens": 16384,
      "use_for": ["translate", "multilingual"],
      "candidates": ["glm-4.7-flash", "qwen3.6-default"],
      "risk_level": "low",
      "_backend_class": "openai-compatible",
      "_residency": "on_demand",
      "_systemd": "glm4-flash-llama.service",
      "_note": "GLM-4.7 Flash for Chinese/multilingual. Small model, fast load."
    },
    "gemma4_31b": {
      "model": "gemma4-31b",
      "temperature": 0.15,
      "max_chars": 50000,
      "max_output_chars": 5000,
      "max_output_tokens": 16384,
      "use_for": ["committee-review", "docs-agent"],
      "candidates": ["gemma4-31b", "qwen3.6-deep"],
      "risk_level": "medium",
      "_backend_class": "openai-compatible",
      "_residency": "on_demand",
      "_systemd": "gemma4-31b-llama.service",
      "_note": "Gemma4 31B for cross-family committee review. On-demand — start before committee."
    },
    "docs_agent": {
      "model": "qwen3.6-deep",
      "temperature": 0.1,
      "max_chars": 40000,
      "max_output_chars": 5000,
      "max_output_tokens": 16384,
      "use_for": ["documentation", "governance"],
      "candidates": ["qwen3.6-deep", "qwen3-coder-30b"],
      "risk_level": "low",
      "_backend_class": "openai-compatible",
      "_residency": "resident",
      "_note": "Documentation agent on resident qwen3.6."
    },

    "fast_summary_light": {
      "model": "gemma4-12b",
      "temperature": 0.2,
      "max_chars": 24000,
      "max_output_chars": 3000,
      "max_output_tokens": 16384,
      "use_for": ["summarize-file", "summarize-tree"],
      "candidates": ["gemma4-12b", "qwen3.5-claude-opus-9b"],
      "risk_level": "low",
      "_backend_class": "openai-compatible",
      "_residency": "on_demand",
      "_systemd": "gemma4-12b-llama.service",
      "_note": "Gemma4 12B — tiny 6GB model for fast summaries. On-demand."
    },
    "heavy_reviewer": {
      "model": "qwen3.6-35b",
      "temperature": 0.1,
      "max_chars": 60000,
      "max_output_chars": 6000,
      "max_output_tokens": 16384,
      "use_for": ["deep-code-review", "release-risk-review"],
      "candidates": ["qwen3.6-35b", "qwen3.6-deep"],
      "risk_level": "high",
      "_backend_class": "openai-compatible",
      "_residency": "on_demand",
      "_systemd": "qwen36-35b-llama.service",
      "_note": "Qwen3.6 35B — heavy lifter for deep review. On-demand."
    },
    "_deprecated_ollama": {
      "_note": "Below profiles are Ollama-only, kept for reference. Not usable without Ollama running.",
      "smart_summary": {"model": "qwen3.5-claude-opus:9b", "_backend_class": "ollama", "_status": "deprecated"},
      "heavy_reviewer": {"model": "gpt-oss:120b", "_backend_class": "ollama", "_status": "deprecated"},
      "gemma4_26b": {"model": "gemma4:26b", "_backend_class": "ollama", "_status": "deprecated"},
      "nemotron_super": {"model": "nemotron:super", "_backend_class": "ollama", "_status": "deprecated"},
      "deepseek_r1_70b": {"model": "deepseek-r1:70b", "_backend_class": "ollama", "_status": "deprecated"},
      "embedding": {"model": "nomic-embed:latest", "_backend_class": "ollama", "_status": "deprecated"}
    }
  }
}
